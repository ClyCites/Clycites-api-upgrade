{
  "name": "clycites-api",
  "version": "1.0.0",
  "description": "ClyCites Agricultural E-Market Platform API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/app.ts",
    "dev:auth": "nodemon --exec ts-node src/services/auth/app.ts",
    "dev:farmers": "nodemon --exec ts-node src/services/farmers/app.ts",
    "dev:products": "nodemon --exec ts-node src/services/products/app.ts",
    "dev:marketplace": "nodemon --exec ts-node src/services/marketplace/app.ts",
    "dev:orders": "nodemon --exec ts-node src/services/orders/app.ts",
    "dev:notifications": "nodemon --exec ts-node src/services/notifications/app.ts",
    "dev:analytics": "nodemon --exec ts-node src/services/analytics/app.ts",
    "dev:price-monitor": "python flask-app/app.py",
    "dev:all": "concurrently -n auth,farmers,products,marketplace,orders,notifications,analytics,price-monitor -c blue,green,magenta,cyan,yellow,gray,white,red \"npm:dev:auth\" \"npm:dev:farmers\" \"npm:dev:products\" \"npm:dev:marketplace\" \"npm:dev:orders\" \"npm:dev:notifications\" \"npm:dev:analytics\" \"npm:dev:price-monitor\"",
    "build": "tsc",
    "start": "node dist/app.js",
    "start:prod": "node ts-node src/app.ts",
    "start:auth": "node dist/services/auth/app.js",
    "start:farmers": "node dist/services/farmers/app.js",
    "start:products": "node dist/services/products/app.js",
    "start:marketplace": "node dist/services/marketplace/app.js",
    "start:orders": "node dist/services/orders/app.js",
    "start:notifications": "node dist/services/notifications/app.js",
    "start:analytics": "node dist/services/analytics/app.js",
    "start:price-monitor": "python flask-app/app.py",
    "start:all": "concurrently -n auth,farmers,products,marketplace,orders,notifications,analytics,price-monitor -c blue,green,magenta,cyan,yellow,gray,white,red \"npm:start:auth\" \"npm:start:farmers\" \"npm:start:products\" \"npm:start:marketplace\" \"npm:start:orders\" \"npm:start:notifications\" \"npm:start:analytics\" \"npm:start:price-monitor\"",
    "init:iam": "ts-node src/scripts/initializeIAM.ts",
    "seed": "ts-node src/scripts/seed.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix"
  },
  "keywords": [
    "agriculture",
    "marketplace",
    "api",
    "nodejs",
    "express"
  ],
  "author": "ClyCites Team",
  "license": "MIT",
  "dependencies": {
    "@types/swagger-ui-express": "^4.1.8",
    "argon2": "^0.31.2",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^3.0.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "form-data": "^4.0.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "qrcode": "^1.5.3",
    "rate-limit-redis": "^4.1.0",
    "sharp": "^0.34.5",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.6",
    "@types/nodemailer": "^6.4.14",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "openapi-types": "^12.1.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
