# .gitignore for GitHub Actions

# GitHub Actions
.github/
!.github/workflows/
!.github/ISSUE_TEMPLATE/
!.github/PULL_REQUEST_TEMPLATE.md
!.github/CODEOWNERS
!.github/dependabot.yml
!.github/renovate.json

# Action logs
*.log
logs/

# Artifacts
dist/
build/
.next/

# Environment
.env
.env.local
.env.*.local

# Dependencies  
node_modules/
vendor/
__pycache__/
*.egg-info/
.venv/
venv/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS
Thumbs.db
.DS_Store

# Test coverage
coverage/
.nyc_output/

# Build artifacts (these are generated)
*.min.js
*.min.css
