# PEST & DISEASE DETECTION MODULE - ENVIRONMENT VARIABLES

# Copy this to your main .env file and configure values

# ------------------------------------------------------------
# AI DETECTION CONFIGURATION
# ------------------------------------------------------------

# AI Provider Selection
# Options: mock | plantvillage | custom | tensorflow | pytorch
# Recommendation: Use 'mock' for development, 'plantvillage' or 'custom' for production
AI_DETECTION_PROVIDER=mock

# Custom AI Provider Settings (required if AI_DETECTION_PROVIDER=custom)
AI_DETECTION_API_ENDPOINT=https://your-ai-api.com/v1/detect
AI_DETECTION_API_KEY=your-api-key-here

# Model Configuration
AI_MODEL_NAME=PlantDisease-ResNet50
AI_MODEL_VERSION=v1.0.0
AI_INFERENCE_ENGINE=TensorFlow

# Detection Thresholds
# Minimum confidence score (0-100) to auto-accept detection without expert review
AI_CONFIDENCE_THRESHOLD=60

# Maximum number of alternative predictions to return
AI_MAX_ALTERNATIVES=3

# AI API request timeout (milliseconds)
AI_REQUEST_TIMEOUT=30000

# Enable bounding box detection (if supported by provider)
AI_ENABLE_BOUNDING_BOXES=true

# ------------------------------------------------------------
# IMAGE STORAGE CONFIGURATION
# ------------------------------------------------------------

# Storage Provider Selection
# Options: local | s3 | azure | gcs
# Recommendation: Use 'local' for development, cloud providers for production
IMAGE_STORAGE_PROVIDER=local

# Base URL for image access (adjust based on your deployment)
IMAGE_STORAGE_BASE_URL=http://localhost:3000

# Local Filesystem Storage (required if IMAGE_STORAGE_PROVIDER=local)
IMAGE_STORAGE_PATH=./uploads/pest-disease

# AWS S3 Configuration (required if IMAGE_STORAGE_PROVIDER=s3)
IMAGE_STORAGE_BUCKET=your-s3-bucket-name
IMAGE_STORAGE_REGION=us-east-1
IMAGE_STORAGE_ACCESS_KEY_ID=your-aws-access-key
IMAGE_STORAGE_SECRET_ACCESS_KEY=your-aws-secret-key

# Azure Blob Storage (required if IMAGE_STORAGE_PROVIDER=azure)
IMAGE_STORAGE_ACCOUNT_NAME=your-azure-account
IMAGE_STORAGE_ACCOUNT_KEY=your-azure-key
IMAGE_STORAGE_CONTAINER=pest-disease-images

# Google Cloud Storage (required if IMAGE_STORAGE_PROVIDER=gcs)
IMAGE_STORAGE_GCS_PROJECT_ID=your-gcs-project-id
IMAGE_STORAGE_GCS_KEYFILE=./path/to/gcs-keyfile.json

# Image Processing Settings
IMAGE_MAX_SIZE=10485760  # 10MB in bytes
IMAGE_MAX_FILES=10       # Maximum images per detection request

# Thumbnail Generation
IMAGE_GENERATE_THUMBNAILS=true
IMAGE_THUMBNAIL_WIDTH=320
IMAGE_THUMBNAIL_HEIGHT=240
IMAGE_THUMBNAIL_QUALITY=80

# Image Optimization
IMAGE_JPEG_QUALITY=85
IMAGE_PNG_COMPRESSION_LEVEL=8
IMAGE_WEBP_QUALITY=85

# Validation Settings
IMAGE_MIN_WIDTH=100
IMAGE_MIN_HEIGHT=100
IMAGE_MAX_WIDTH=4096
IMAGE_MAX_HEIGHT=4096

# Security
IMAGE_VIRUS_SCAN=false  # Enable ClamAV virus scanning
IMAGE_CHECKSUM_ALGORITHM=sha256

# ------------------------------------------------------------
# OUTBREAK ANALYTICS CONFIGURATION
# ------------------------------------------------------------

# Outbreak Detection Parameters
OUTBREAK_MIN_REPORTS_THRESHOLD=5      # Minimum reports to trigger outbreak
OUTBREAK_TIME_WINDOW_DAYS=14          # Time window for clustering reports
OUTBREAK_MIN_CONFIDENCE_SCORE=60      # Minimum confidence to include in outbreak

# Hotspot Detection
HOTSPOT_DEFAULT_RADIUS_KM=50          # Default clustering radius
HOTSPOT_MIN_CLUSTER_SIZE=3            # Minimum reports per hotspot
HOTSPOT_GRID_SIZE_KM=10               # Grid cell size for clustering

# Severity Index Calculation Weights (must sum to 1.0)
SEVERITY_WEIGHT_REPORT_COUNT=0.30
SEVERITY_WEIGHT_CONFIRMATION_RATE=0.20
SEVERITY_WEIGHT_FARMS_AFFECTED=0.20
SEVERITY_WEIGHT_OUTBREAK_LEVEL=0.30

# Trend Analysis
TREND_DEFAULT_CURRENT_PERIOD_DAYS=30
TREND_DEFAULT_PREVIOUS_PERIOD_DAYS=30
TREND_CHANGE_THRESHOLD_PERCENT=20     # Threshold for "increasing/decreasing" classification

# ------------------------------------------------------------
# EXPERT REVIEW CONFIGURATION
# ------------------------------------------------------------

# Auto-flagging Rules
EXPERT_REVIEW_LOW_CONFIDENCE_THRESHOLD=60
EXPERT_REVIEW_AUTO_FLAG_CONFLICTING_PREDICTIONS=true

# Review Notifications
EXPERT_REVIEW_NOTIFY_EMAIL=true
EXPERT_REVIEW_NOTIFY_SMS=false

# ------------------------------------------------------------
# KNOWLEDGE BASE CONFIGURATION
# ------------------------------------------------------------

# Content Management
KNOWLEDGE_BASE_ENABLE_VERSIONING=true
KNOWLEDGE_BASE_REQUIRE_ADMIN_APPROVAL=true

# Search Settings
KNOWLEDGE_BASE_FUZZY_SEARCH=true
KNOWLEDGE_BASE_MAX_SEARCH_RESULTS=50

# ------------------------------------------------------------
# NOTIFICATION SETTINGS
# ------------------------------------------------------------

# Farmer Notifications
NOTIFY_FARMER_ON_DETECTION_COMPLETE=true
NOTIFY_FARMER_ON_EXPERT_REVIEW=true
NOTIFY_FARMER_ON_OUTBREAK_ALERT=true

# Extension Officer Notifications
NOTIFY_OFFICER_ON_REVIEW_REQUIRED=true
NOTIFY_OFFICER_ON_OUTBREAK_DETECTED=true

# Notification Channels
NOTIFICATION_CHANNEL_EMAIL=true
NOTIFICATION_CHANNEL_SMS=true
NOTIFICATION_CHANNEL_PUSH=true
NOTIFICATION_CHANNEL_IN_APP=true

# ------------------------------------------------------------
# PERFORMANCE & RATE LIMITING
# ------------------------------------------------------------

# API Rate Limits
RATE_LIMIT_DETECTION_PER_HOUR=20      # Detection requests per farmer per hour
RATE_LIMIT_ANALYTICS_PER_HOUR=100     # Analytics requests per user per hour

# Background Processing
ENABLE_ASYNC_AI_PROCESSING=true
ENABLE_BACKGROUND_OUTBREAK_DETECTION=true

# Caching
CACHE_TREATMENT_KNOWLEDGE_TTL=3600    # Cache treatment data (seconds)
CACHE_ANALYTICS_DASHBOARD_TTL=900     # Cache dashboard analytics (seconds)

# ------------------------------------------------------------
# COMPLIANCE & SECURITY
# ------------------------------------------------------------

# Consent Management
REQUIRE_FARMER_CONSENT=true
CONSENT_VERSION=v1.0
CONSENT_MIN_AGE=18

# Data Retention
DATA_RETENTION_REPORTS_DAYS=730       # 2 years
DATA_RETENTION_IMAGES_DAYS=365        # 1 year
DATA_RETENTION_OUTBREAKS_DAYS=1095    # 3 years

# Audit Logging
ENABLE_AUDIT_LOGGING=true
AUDIT_LOG_LEVEL=info                  # debug | info | warn | error

# Privacy
ANONYMIZE_FARMER_DATA_AFTER_DAYS=365
ENABLE_GDPR_COMPLIANCE=true
ENABLE_DATA_EXPORT=true

# ------------------------------------------------------------
# DEVELOPMENT & DEBUGGING
# ------------------------------------------------------------

# Mock Data Generation
MOCK_AI_DELAY_MS=2000                 # Simulate AI processing delay
MOCK_AI_RANDOM_CONFIDENCE=true        # Randomize confidence scores

# Development Features
ENABLE_DEBUG_LOGGING=false
ENABLE_PERFORMANCE_METRICS=false
ENABLE_REQUEST_LOGGING=false

# Testing
TEST_MODE=false
TEST_SKIP_IMAGE_VALIDATION=false
TEST_SKIP_AI_PROCESSING=false

# ------------------------------------------------------------
# INTEGRATION SETTINGS
# ------------------------------------------------------------

# Weather API Integration (for field context)
WEATHER_API_PROVIDER=openweathermap
WEATHER_API_KEY=your-weather-api-key
WEATHER_API_ENDPOINT=https://api.openweathermap.org/data/2.5

# External Farm Management System
FARM_MANAGEMENT_SYSTEM_INTEGRATION=false
FARM_MANAGEMENT_API_ENDPOINT=https://your-fms.com/api

# Insurance Provider Integration
INSURANCE_INTEGRATION_ENABLED=false
INSURANCE_API_ENDPOINT=https://insurance-provider.com/api
INSURANCE_API_KEY=your-insurance-api-key

# ------------------------------------------------------------
# MONITORING & ALERTS
# ------------------------------------------------------------

# Health Checks
ENABLE_HEALTH_CHECK_ENDPOINT=true
HEALTH_CHECK_INTERVAL_MINUTES=5

# Alerting
ALERT_ON_AI_PROVIDER_FAILURE=true
ALERT_ON_STORAGE_FAILURE=true
ALERT_ON_OUTBREAK_DETECTED=true

# Metrics
ENABLE_PROMETHEUS_METRICS=false
METRICS_PORT=9090

# ------------------------------------------------------------
# EXAMPLE CONFIGURATIONS
# ------------------------------------------------------------

# DEVELOPMENT SETUP (Local Testing)
# AI_DETECTION_PROVIDER=mock
# IMAGE_STORAGE_PROVIDER=local
# IMAGE_STORAGE_PATH=./uploads/pest-disease
# ENABLE_DEBUG_LOGGING=true

# STAGING SETUP (Cloud Testing)
# AI_DETECTION_PROVIDER=plantvillage
# IMAGE_STORAGE_PROVIDER=s3
# IMAGE_STORAGE_BUCKET=clycites-staging-pest-disease
# ENABLE_ASYNC_AI_PROCESSING=true

# PRODUCTION SETUP (Live Deployment)
# AI_DETECTION_PROVIDER=custom
# AI_DETECTION_API_ENDPOINT=https://ai.clycites.com/detect
# IMAGE_STORAGE_PROVIDER=s3
# IMAGE_STORAGE_BUCKET=clycites-prod-pest-disease
# ENABLE_ASYNC_AI_PROCESSING=true
# ENABLE_BACKGROUND_OUTBREAK_DETECTION=true
# REQUIRE_FARMER_CONSENT=true
# ENABLE_AUDIT_LOGGING=true
